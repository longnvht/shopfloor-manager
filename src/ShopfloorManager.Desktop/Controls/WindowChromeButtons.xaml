<UserControl x:Class="ShopfloorManager.Desktop.Controls.WindowChromeButtons"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Window chrome — thay cho titlebar mặc định của Windows (đã ẩn qua WindowStyle=None trên MainWindow) -->
    <StackPanel Orientation="Horizontal">
        <StackPanel.Resources>
            <!-- Tag mang màu hover (mặc định mờ trắng, nút Close override thành đỏ) -->
            <Style x:Key="WinChromeButton" TargetType="Button">
                <Setter Property="Width" Value="44"/>
                <Setter Property="Height" Value="52"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Tag" Value="#33FFFFFF"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </StackPanel.Resources>
        <Button Click="Minimize_Click" Style="{StaticResource WinChromeButton}">
            <md:PackIcon Kind="WindowMinimize" Width="16" Height="16" Foreground="White"/>
        </Button>
        <Button Click="MaximizeRestore_Click" Style="{StaticResource WinChromeButton}">
            <md:PackIcon x:Name="MaximizeIcon" Kind="WindowMaximize" Width="15" Height="15" Foreground="White"/>
        </Button>
        <Button Click="Close_Click" Style="{StaticResource WinChromeButton}" Tag="#D32F2F">
            <md:PackIcon Kind="WindowClose" Width="16" Height="16" Foreground="White"/>
        </Button>
    </StackPanel>
</UserControl>
