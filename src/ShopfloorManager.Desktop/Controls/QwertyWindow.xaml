<Window x:Class="ShopfloorManager.Desktop.Controls.QwertyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keyboard"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Key chữ thường: nâu tối -->
        <Style x:Key="Key" TargetType="Button">
            <Setter Property="Width" Value="62"/>
            <Setter Property="Height" Value="62"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="2.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#FF5D3A1A" CornerRadius="8"
                                BorderBrush="#FF8B5A2B" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFA0522D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Key chức năng: nâu đậm -->
        <Style x:Key="FnKey" TargetType="Button" BasedOn="{StaticResource Key}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#FF4A2A0E" CornerRadius="8"
                                BorderBrush="#FF7A4A1E" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF8B5A2B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CAPS toggle: đổi cam khi bật -->
        <Style x:Key="CapsKey" TargetType="ToggleButton">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="62"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="2.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="#FF4A2A0E" CornerRadius="8"
                                BorderBrush="#FF7A4A1E" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFE65100"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FFFF8C00"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF8B5A2B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 123 toggle -->
        <Style x:Key="NumToggleKey" TargetType="ToggleButton" BasedOn="{StaticResource CapsKey}">
            <Setter Property="Width" Value="90"/>
        </Style>
    </Window.Resources>

    <!-- Container: nâu tối bán trong suốt -->
    <Border CornerRadius="14" Background="#EE3E2000"
            BorderBrush="#FF8B5A2B" BorderThickness="1.5" Padding="12,10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="4" Color="#3E2000"/>
        </Border.Effect>
        <StackPanel>
            <!-- QWERTY Panel -->
            <StackPanel x:Name="QwertyPanel">
                <!-- Row 1: Q-P + Backspace -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="q" Style="{StaticResource Key}" Click="OnKey" Tag="q"/>
                    <Button Content="w" Style="{StaticResource Key}" Click="OnKey" Tag="w"/>
                    <Button Content="e" Style="{StaticResource Key}" Click="OnKey" Tag="e"/>
                    <Button Content="r" Style="{StaticResource Key}" Click="OnKey" Tag="r"/>
                    <Button Content="t" Style="{StaticResource Key}" Click="OnKey" Tag="t"/>
                    <Button Content="y" Style="{StaticResource Key}" Click="OnKey" Tag="y"/>
                    <Button Content="u" Style="{StaticResource Key}" Click="OnKey" Tag="u"/>
                    <Button Content="i" Style="{StaticResource Key}" Click="OnKey" Tag="i"/>
                    <Button Content="o" Style="{StaticResource Key}" Click="OnKey" Tag="o"/>
                    <Button Content="p" Style="{StaticResource Key}" Click="OnKey" Tag="p"/>
                    <Button Width="90" Height="62" Margin="2.5" Style="{StaticResource FnKey}"
                            FontSize="22" Click="OnBackspace">
                        <TextBlock Text="⌫"/>
                    </Button>
                </StackPanel>

                <!-- Row 2: A-L + Enter -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="a" Style="{StaticResource Key}" Click="OnKey" Tag="a"/>
                    <Button Content="s" Style="{StaticResource Key}" Click="OnKey" Tag="s"/>
                    <Button Content="d" Style="{StaticResource Key}" Click="OnKey" Tag="d"/>
                    <Button Content="f" Style="{StaticResource Key}" Click="OnKey" Tag="f"/>
                    <Button Content="g" Style="{StaticResource Key}" Click="OnKey" Tag="g"/>
                    <Button Content="h" Style="{StaticResource Key}" Click="OnKey" Tag="h"/>
                    <Button Content="j" Style="{StaticResource Key}" Click="OnKey" Tag="j"/>
                    <Button Content="k" Style="{StaticResource Key}" Click="OnKey" Tag="k"/>
                    <Button Content="l" Style="{StaticResource Key}" Click="OnKey" Tag="l"/>
                    <Button Width="155" Height="62" Margin="2.5" Style="{StaticResource FnKey}"
                            FontSize="15" Content="Enter ↵" Click="OnConfirm"/>
                </StackPanel>

                <!-- Row 3: Caps + Z-M -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ToggleButton x:Name="CapsBtn" Content="⇪ CAPS" Style="{StaticResource CapsKey}"
                                  Checked="OnCapsChanged" Unchecked="OnCapsChanged"/>
                    <Button x:Name="BtnZ" Content="z" Style="{StaticResource Key}" Click="OnKey" Tag="z"/>
                    <Button x:Name="BtnX" Content="x" Style="{StaticResource Key}" Click="OnKey" Tag="x"/>
                    <Button x:Name="BtnC" Content="c" Style="{StaticResource Key}" Click="OnKey" Tag="c"/>
                    <Button x:Name="BtnV" Content="v" Style="{StaticResource Key}" Click="OnKey" Tag="v"/>
                    <Button x:Name="BtnB" Content="b" Style="{StaticResource Key}" Click="OnKey" Tag="b"/>
                    <Button x:Name="BtnN" Content="n" Style="{StaticResource Key}" Click="OnKey" Tag="n"/>
                    <Button x:Name="BtnM" Content="m" Style="{StaticResource Key}" Click="OnKey" Tag="m"/>
                    <Button Content="-" Style="{StaticResource Key}" Click="OnKey" Tag="-"/>
                    <Button Content="." Style="{StaticResource Key}" Click="OnKey" Tag="."/>
                </StackPanel>

                <!-- Row 4: Xóa + Space + 123 + Đóng -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Width="90" Height="54" Margin="2.5" Style="{StaticResource FnKey}"
                            FontSize="14" Content="Xóa" Click="OnClear"/>
                    <Button Width="460" Height="54" Margin="2.5" Style="{StaticResource Key}"
                            Content="SPACE" FontSize="14" Click="OnKey" Tag=" "/>
                    <ToggleButton x:Name="NumToggleBtn" Width="90" Height="54" Margin="2.5"
                                  Style="{StaticResource NumToggleKey}"
                                  Content="123" FontSize="15"
                                  Checked="OnShowNumeric" Unchecked="OnShowQwerty"/>
                    <Button Width="90" Height="54" Margin="2.5" Style="{StaticResource FnKey}"
                            FontSize="13" Content="✕ Đóng" Click="OnClose"/>
                </StackPanel>
            </StackPanel>

            <!-- Numeric / Symbol Panel -->
            <StackPanel x:Name="NumericPanel" Visibility="Collapsed">
                <!-- Row 1: 1-9 + Backspace -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="1" Style="{StaticResource Key}" Click="OnKey" Tag="1"/>
                    <Button Content="2" Style="{StaticResource Key}" Click="OnKey" Tag="2"/>
                    <Button Content="3" Style="{StaticResource Key}" Click="OnKey" Tag="3"/>
                    <Button Content="4" Style="{StaticResource Key}" Click="OnKey" Tag="4"/>
                    <Button Content="5" Style="{StaticResource Key}" Click="OnKey" Tag="5"/>
                    <Button Content="6" Style="{StaticResource Key}" Click="OnKey" Tag="6"/>
                    <Button Content="7" Style="{StaticResource Key}" Click="OnKey" Tag="7"/>
                    <Button Content="8" Style="{StaticResource Key}" Click="OnKey" Tag="8"/>
                    <Button Content="9" Style="{StaticResource Key}" Click="OnKey" Tag="9"/>
                    <Button Content="0" Style="{StaticResource Key}" Click="OnKey" Tag="0"/>
                    <Button Width="90" Height="62" Margin="2.5" Style="{StaticResource FnKey}"
                            FontSize="22" Click="OnBackspace">
                        <TextBlock Text="⌫"/>
                    </Button>
                </StackPanel>

                <!-- Row 2: Ký tự đặc biệt -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="!" Style="{StaticResource Key}" Click="OnKey" Tag="!"/>
                    <Button Content="@" Style="{StaticResource Key}" Click="OnKey" Tag="@"/>
                    <Button Content="#" Style="{StaticResource Key}" Click="OnKey" Tag="#"/>
                    <Button Content="$" Style="{StaticResource Key}" Click="OnKey" Tag="$"/>
                    <Button Content="%" Style="{StaticResource Key}" Click="OnKey" Tag="%"/>
                    <Button Content="&amp;" Style="{StaticResource Key}" Click="OnKey" Tag="&amp;"/>
                    <Button Content="*" Style="{StaticResource Key}" Click="OnKey" Tag="*"/>
                    <Button Content="(" Style="{StaticResource Key}" Click="OnKey" Tag="("/>
                    <Button Content=")" Style="{StaticResource Key}" Click="OnKey" Tag=")"/>
                    <Button Content="_" Style="{StaticResource Key}" Click="OnKey" Tag="_"/>
                    <Button Width="90" Height="62" Margin="2.5" Style="{StaticResource FnKey}"
                            FontSize="15" Content="Enter ↵" Click="OnConfirm"/>
                </StackPanel>

                <!-- Row 3 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="+" Style="{StaticResource Key}" Click="OnKey" Tag="+"/>
                    <Button Content="-" Style="{StaticResource Key}" Click="OnKey" Tag="-"/>
                    <Button Content="=" Style="{StaticResource Key}" Click="OnKey" Tag="="/>
                    <Button Content="/" Style="{StaticResource Key}" Click="OnKey" Tag="/"/>
                    <Button Content="\" Style="{StaticResource Key}" Click="OnKey" Tag="\"/>
                    <Button Content=":" Style="{StaticResource Key}" Click="OnKey" Tag=":"/>
                    <Button Content=";" Style="{StaticResource Key}" Click="OnKey" Tag=";"/>
                    <Button Content="'" Style="{StaticResource Key}" Click="OnKey" Tag="'"/>
                    <Button Content="&quot;" Style="{StaticResource Key}" Click="OnKey" Tag="&quot;"/>
                    <Button Content="." Style="{StaticResource Key}" Click="OnKey" Tag="."/>
                </StackPanel>

                <!-- Row 4 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Width="90" Height="54" Margin="2.5" Style="{StaticResource FnKey}"
                            FontSize="14" Content="Xóa" Click="OnClear"/>
                    <Button Width="460" Height="54" Margin="2.5" Style="{StaticResource Key}"
                            Content="SPACE" FontSize="14" Click="OnKey" Tag=" "/>
                    <ToggleButton x:Name="AbcToggleBtn" Width="90" Height="54" Margin="2.5"
                                  Style="{StaticResource NumToggleKey}"
                                  Content="ABC" FontSize="15" IsChecked="True"
                                  Checked="OnShowQwerty" Unchecked="OnShowNumeric"/>
                    <Button Width="90" Height="54" Margin="2.5" Style="{StaticResource FnKey}"
                            FontSize="13" Content="✕ Đóng" Click="OnClose"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
