<Window x:Class="ShopfloorManager.Desktop.Controls.NumPadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NumPad"
        Width="320" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Key số: nền trắng, viền bo nâu -->
        <Style x:Key="NumKey" TargetType="Button">
            <Setter Property="Width" Value="82"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#3E2723"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="White"
                                CornerRadius="10"
                                BorderBrush="#A0522D"
                                BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFE0B2"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#6D3B1A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFF3E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Key chức năng: nền cam kem nhạt -->
        <Style x:Key="ActionKey" TargetType="Button" BasedOn="{StaticResource NumKey}">
            <Setter Property="Foreground" Value="#5D3A1A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="#FFE0B2"
                                CornerRadius="10"
                                BorderBrush="#A0522D"
                                BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFCC80"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#6D3B1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Key xác nhận: xanh lá -->
        <Style x:Key="ConfirmKey" TargetType="Button" BasedOn="{StaticResource NumKey}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="#2E7D32"
                                CornerRadius="10"
                                BorderBrush="#1B5E20"
                                BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Container: nền cam kem, viền bo nâu -->
    <Border CornerRadius="16"
            Background="#FFF8F0"
            BorderBrush="#A0522D"
            BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" Opacity="0.25" ShadowDepth="4" Color="#6D3B1A"/>
        </Border.Effect>

        <StackPanel Margin="12">
            <!-- Drag handle -->
            <Border Height="22" Cursor="SizeAll" Background="Transparent"
                    MouseLeftButtonDown="OnDragHandle_MouseDown" Margin="0,0,0,4">
                <TextBlock Text="⠿" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#A0522D" FontSize="16" Opacity="0.6"/>
            </Border>

            <!-- Display -->
            <Border Background="#3E2723" CornerRadius="8" Margin="0,0,0,10" Padding="12,8">
                <TextBlock x:Name="DisplayText"
                           Text="0"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#FF8C00"
                           HorizontalAlignment="Right"
                           FontFamily="Consolas"/>
            </Border>

            <!-- 7 8 9 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="7" Style="{StaticResource NumKey}" Click="OnKey" Tag="7"/>
                <Button Content="8" Style="{StaticResource NumKey}" Click="OnKey" Tag="8"/>
                <Button Content="9" Style="{StaticResource NumKey}" Click="OnKey" Tag="9"/>
            </StackPanel>

            <!-- 4 5 6 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="4" Style="{StaticResource NumKey}" Click="OnKey" Tag="4"/>
                <Button Content="5" Style="{StaticResource NumKey}" Click="OnKey" Tag="5"/>
                <Button Content="6" Style="{StaticResource NumKey}" Click="OnKey" Tag="6"/>
            </StackPanel>

            <!-- 1 2 3 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="1" Style="{StaticResource NumKey}" Click="OnKey" Tag="1"/>
                <Button Content="2" Style="{StaticResource NumKey}" Click="OnKey" Tag="2"/>
                <Button Content="3" Style="{StaticResource NumKey}" Click="OnKey" Tag="3"/>
            </StackPanel>

            <!-- ± 0 . -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="±" Style="{StaticResource ActionKey}" Click="OnToggleSign"/>
                <Button Content="0" Style="{StaticResource NumKey}" Click="OnKey" Tag="0"/>
                <Button Content="." Style="{StaticResource NumKey}" Click="OnKey" Tag="."/>
            </StackPanel>

            <!-- Xóa ⌫ OK -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                <Button Width="82" Height="52" Margin="3" Style="{StaticResource ActionKey}"
                        FontSize="13" Content="Xóa" Click="OnClear"/>
                <Button Width="82" Height="52" Margin="3" Style="{StaticResource ActionKey}"
                        FontSize="20" Click="OnBackspace">
                    <TextBlock Text="⌫"/>
                </Button>
                <Button Width="82" Height="52" Margin="3" Style="{StaticResource ConfirmKey}"
                        FontSize="14" Content="✓ OK" Click="OnConfirm"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
