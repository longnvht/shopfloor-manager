<Window x:Class="ShopfloorManager.Desktop.Controls.NcrDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:kb="clr-namespace:ShopfloorManager.Desktop.Behaviors"
        Title="NCR"
        Width="520" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Department chip -->
        <Style x:Key="DeptChip" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" CornerRadius="22" Padding="18,10"
                                Background="White"
                                BorderBrush="#A0522D" BorderThickness="1.5">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#6D3B1A"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#3E2723"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFE0B2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Reason card -->
        <Style x:Key="ReasonCard" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" CornerRadius="8" Padding="14,12"
                                Background="White"
                                BorderBrush="#E8D5C4" BorderThickness="1.5">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFF3E0"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#6D3B1A"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="2.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFF8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16"
            Background="#FFF8F0"
            BorderBrush="#A0522D"
            BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="6" Color="#6D3B1A"/>
        </Border.Effect>

        <StackPanel>
            <!-- Drag handle -->
            <Border Height="22" Cursor="SizeAll" Background="Transparent"
                    MouseLeftButtonDown="OnDragHandle_MouseDown" Margin="0,0,0,0">
                <TextBlock Text="⠿" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#A0522D" FontSize="16" Opacity="0.6"/>
            </Border>

            <!-- Title + fail info -->
            <Border Background="#3E2723" Margin="12,0,12,0" CornerRadius="10" Padding="16,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="18" Foreground="#FF8C00" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="KÍCH THƯỚC KHÔNG ĐẠT" FontSize="15" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding BalloonSummary, Mode=OneWay}"
                               Foreground="#FFCC80" FontSize="12"
                               Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <StackPanel Margin="16,14,16,16">

                <!-- Loading indicator -->
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True" Width="28" Height="28"
                             HorizontalAlignment="Center" Margin="0,8,0,8"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Department section -->
                <TextBlock Text="PHÒNG BAN CHỊU TRÁCH NHIỆM"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource BrandTextSecondary}"
                           Margin="0,0,0,8"/>
                <ListBox ItemsSource="{Binding Departments}"
                         SelectedItem="{Binding SelectedDepartment}"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource DeptChip}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         RequestBringIntoView="OnListBoxRequestBringIntoView"
                         Margin="0,0,0,4">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name, Mode=OneWay}"
                                       FontSize="14" FontWeight="Medium"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Reason ComboBox (visible khi đã chọn dept) -->
                <StackPanel Visibility="{Binding ShowReasons, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,8,0,0">
                    <TextBlock Text="LÝ DO"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource BrandTextSecondary}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding FilteredReasons}"
                              SelectedItem="{Binding SelectedReason}"
                              Height="52" FontSize="14"
                              md:HintAssist.Hint="Chọn lý do..."
                              md:HintAssist.IsFloating="False">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding Name, Mode=OneWay}"
                                               FontSize="14" FontWeight="Medium"
                                               Foreground="{StaticResource BrandText}"/>
                                    <TextBlock Text="{Binding Tag, Mode=OneWay}"
                                               FontSize="11"
                                               Foreground="{StaticResource BrandTextSecondary}"
                                               Visibility="{Binding Tag, Converter={StaticResource StringToVisibilityConverter}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Description -->
                <TextBlock Text="{Binding DescriptionLabel, Mode=OneWay}"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource BrandTextSecondary}"
                           Margin="0,14,0,6"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         kb:KeyboardBehavior.Mode="Qwerty"
                         md:HintAssist.Hint="Mô tả thêm về lỗi..."
                         md:HintAssist.IsFloating="False"
                         MinHeight="0" Height="48" FontSize="14"/>

                <!-- Error message -->
                <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                           Foreground="#C62828" FontSize="12" Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Buttons -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Command="{Binding SkipCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="52" FontSize="14"
                            BorderBrush="{StaticResource BrandPrimary}"
                            Foreground="{StaticResource BrandPrimary}"
                            MinHeight="0"
                            Content="Bỏ qua"/>

                    <Button Grid.Column="2"
                            Command="{Binding CreateNcrCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource BrandPrimary}"
                            Foreground="White"
                            Height="52" FontSize="14" FontWeight="Medium"
                            MinHeight="0"
                            Content="✓ Tạo NCR"/>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
