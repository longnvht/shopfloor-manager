<Window x:Class="ShopfloorManager.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ShopfloorManager.Desktop.ViewModels"
        Title="Shopfloor Manager"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        DataContext="{Binding}">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <DockPanel Grid.Column="0"
                   Background="{DynamicResource MaterialDesign.Brush.Primary}">

            <!-- App title -->
            <StackPanel DockPanel.Dock="Top" Margin="16,24,16,16">
                <TextBlock Text="SHOPFLOOR"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="16"/>
                <TextBlock Text="MANAGER"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="16"/>
                <Separator Margin="0,12,0,4" Background="#33FFFFFF"/>
            </StackPanel>

            <!-- User info -->
            <StackPanel DockPanel.Dock="Top" Margin="16,0,16,16">
                <TextBlock Text="{Binding WelcomeText}"
                           Foreground="White"
                           FontWeight="Medium"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding RoleText}"
                           Foreground="#AAFFFFFF"
                           FontSize="11"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <Separator DockPanel.Dock="Top" Background="#33FFFFFF" Margin="16,0"/>

            <!-- Logout at bottom -->
            <Button DockPanel.Dock="Bottom"
                    Content="Đăng xuất"
                    Command="{Binding LogoutCommand}"
                    Style="{StaticResource NavButtonStyle}"
                    Margin="0,8">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Logout" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <!-- Navigation menu -->
            <StackPanel DockPanel.Dock="Top" Margin="0,8">
                <Button Content="Danh sách Job"
                        Style="{StaticResource NavButtonStyle}"
                        x:Name="BtnJobs">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ClipboardList" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>

                <Button Content="NCR"
                        Style="{StaticResource NavButtonStyle}"
                        x:Name="BtnNcr">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="AlertCircle" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>

                <Button Content="Cài đặt"
                        Style="{StaticResource NavButtonStyle}"
                        x:Name="BtnSettings">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Cog" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Content area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.DataGrid.ColumnHeader.Border}"
                    BorderThickness="0,0,0,1"
                    Padding="24,0">
                <DockPanel Height="56">
                    <TextBlock x:Name="PageTitleText"
                               Text="Danh sách Job"
                               VerticalAlignment="Center"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                </DockPanel>
            </Border>

            <!-- Page content — placeholder, sẽ dùng ContentControl khi có Pages -->
            <Border Grid.Row="1" Padding="24">
                <TextBlock Text="Chọn mục từ menu bên trái để bắt đầu."
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"/>
            </Border>
        </Grid>
    </Grid>
</Window>
