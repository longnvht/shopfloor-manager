<Window x:Class="ShopfloorManager.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shopfloor Manager"
        MinWidth="1024" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource BrandBg}">

    <!-- Shell đơn giản — chỉ ContentControl, không sidebar.
         Dashboard và sub-pages tự quản lý header/navigation của mình. -->
    <ContentControl Content="{Binding CurrentPage}"/>
</Window>
