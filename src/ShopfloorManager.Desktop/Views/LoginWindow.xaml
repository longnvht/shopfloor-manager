<Window x:Class="ShopfloorManager.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:kb="clr-namespace:ShopfloorManager.Desktop.Behaviors"
        xmlns:loc="clr-namespace:ShopfloorManager.Desktop.Localization"
        Title="{loc:Loc Key=Login_WindowTitle}"
        Width="420" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="12" Background="{DynamicResource MaterialDesign.Brush.Background}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="40,40,40,20" HorizontalAlignment="Center">
                <TextBlock Text="{loc:Loc Key=Login_AppName}"
                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{loc:Loc Key=Login_AppSubtitle}"
                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                           Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Form -->
            <StackPanel Grid.Row="1" Margin="40,0" VerticalAlignment="Center">
                <!-- Textbox trần (không dùng MaterialDesignOutlinedTextBox) — template Outlined có margin nội bộ
                     riêng cho phần text (TextBoxViewMargin) không trùng với Padding, gây lệch placeholder vs caret.
                     Tự vẽ Border bo tròn + TextBox Padding để caret và placeholder dùng đúng 1 mốc toạ độ. -->
                <Border CornerRadius="26" Background="White"
                        BorderBrush="{StaticResource BrandPrimaryLight}" BorderThickness="1.5" Height="52">
                    <Grid>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 kb:KeyboardBehavior.Mode="Qwerty"
                                 Style="{x:Null}"
                                 Background="Transparent" BorderThickness="0"
                                 FontSize="15" Padding="44,0,16,0"
                                 VerticalContentAlignment="Center"
                                 IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                        <md:PackIcon Kind="AccountOutline" Width="20" Height="20"
                                     Foreground="{StaticResource BrandTextSecondary}"
                                     HorizontalAlignment="Left" VerticalAlignment="Center"
                                     Margin="16,0,0,0" IsHitTestVisible="False"/>
                        <TextBlock Text="{loc:Loc Key=Login_UsernameHint}"
                                   Foreground="{StaticResource BrandTextSecondary}" Opacity="0.7"
                                   FontSize="15" Margin="44,0,16,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Username}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <Border CornerRadius="26" Background="White" Margin="0,16,0,0"
                        BorderBrush="{StaticResource BrandPrimaryLight}" BorderThickness="1.5" Height="52">
                    <Grid>
                        <PasswordBox Style="{x:Null}"
                                     Background="Transparent" BorderThickness="0"
                                     FontSize="15" Padding="44,0,16,0"
                                     VerticalContentAlignment="Center"
                                     md:PasswordBoxAssist.Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                        <md:PackIcon Kind="LockOutline" Width="20" Height="20"
                                     Foreground="{StaticResource BrandTextSecondary}"
                                     HorizontalAlignment="Left" VerticalAlignment="Center"
                                     Margin="16,0,0,0" IsHitTestVisible="False"/>
                        <TextBlock Text="{loc:Loc Key=Login_PasswordHint}"
                                   Foreground="{StaticResource BrandTextSecondary}" Opacity="0.7"
                                   FontSize="15" Margin="44,0,16,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Password}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <TextBlock Margin="0,8,0,0"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                           TextWrapping="Wrap"/>

                <Button Content="{loc:Loc Key=Login_LoginButton}"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource BrandAccent}"
                        BorderBrush="{StaticResource BrandAccent}"
                        md:ButtonAssist.CornerRadius="26"
                        Height="52"
                        Margin="0,20,0,0"/>
            </StackPanel>

            <!-- Footer -->
            <TextBlock Grid.Row="2"
                       x:Name="MachineInfoText"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"
                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"/>
        </Grid>
    </Border>
</Window>
