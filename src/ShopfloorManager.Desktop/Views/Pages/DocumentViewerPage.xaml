<UserControl x:Class="ShopfloorManager.Desktop.Views.Pages.DocumentViewerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:ShopfloorManager.Desktop.Models"
             xmlns:kb="clr-namespace:ShopfloorManager.Desktop.Behaviors"
             xmlns:ctrl="clr-namespace:ShopfloorManager.Desktop.Controls"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="{StaticResource BrandBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- ══ TITLE BAR ══ -->
        <Border Grid.Row="0" Background="{StaticResource BrandPrimary}"
                kb:WindowDragBehavior.IsDragHandle="True">
            <Grid Margin="16,0,0,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="TÀI LIỆU KỸ THUẬT"
                               Foreground="White" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="{Binding TitleContext, Mode=OneWay}"
                               Foreground="{StaticResource BrandAccentLight}"
                               FontSize="11" Margin="0,1,0,0"/>
                </StackPanel>
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True" Width="24" Height="24"
                             HorizontalAlignment="Right" Margin="0,0,140,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <ctrl:WindowChromeButtons HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- ══ CONTENT: 2-column split ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── Left: document list ─────────────────────────────────── -->
            <Grid Grid.Column="0" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- List header -->
                <Border Grid.Row="0" BorderBrush="#E8D5C4" BorderThickness="0,0,0,1" Padding="12,8">
                    <TextBlock Text="Danh sách tài liệu"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource BrandTextSecondary}"/>
                </Border>

                <!-- Doc list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              PanningMode="VerticalFirst"
                              kb:DragScrollBehavior.Enabled="True">
                    <StackPanel>
                        <!-- Empty state -->
                        <TextBlock Margin="12,20" TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="{StaticResource BrandTextSecondary}" FontSize="12"
                                   Visibility="{Binding NoDocuments, Converter={StaticResource BooleanToVisibilityConverter}}">
                            Chưa có tài liệu được duyệt cho công đoạn này.
                        </TextBlock>

                        <!-- Error state -->
                        <TextBlock Margin="12,20" TextWrapping="Wrap"
                                   Foreground="#C62828" FontSize="12"
                                   Text="{Binding ErrorMessage, Mode=OneWay}"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                        <ListBox ItemsSource="{Binding Documents}"
                                 SelectedItem="{Binding SelectedDocument}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="bd" BorderBrush="#F0E8E0"
                                                        BorderThickness="0,0,0,1" Padding="12,10">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bd" Property="Background"
                                                                Value="{StaticResource BrandAccentLight}"/>
                                                        <Setter TargetName="bd" Property="BorderThickness"
                                                                Value="3,0,0,0"/>
                                                        <Setter TargetName="bd" Property="BorderBrush"
                                                                Value="{StaticResource BrandPrimary}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background"
                                                                Value="#FFF3E0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TechDocDto}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- File type badge -->
                                        <Border Grid.Column="0"
                                                Width="36" Height="36" CornerRadius="6"
                                                Margin="0,0,10,0" VerticalAlignment="Top"
                                                Background="{Binding BadgeColor, Mode=OneWay,
                                                    Converter={StaticResource HexToBrushConverter}}">
                                            <TextBlock Text="{Binding FileTypeCode, Mode=OneWay}"
                                                       Foreground="White" FontSize="9"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Doc info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName, Mode=OneWay}"
                                                       FontSize="12" FontWeight="Medium"
                                                       Foreground="{StaticResource BrandText}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding FileTypeName, Mode=OneWay}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource BrandTextSecondary}"/>
                                                <TextBlock Text=" · "
                                                           FontSize="10"
                                                           Foreground="{StaticResource BrandTextSecondary}"/>
                                                <TextBlock FontSize="10"
                                                           Foreground="{StaticResource BrandTextSecondary}">
                                                    <Run Text="{Binding CreatedAt, Mode=OneWay,
                                                        StringFormat={}{0:dd/MM/yy}}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ─── Divider ──────────────────────────────────────────────── -->
            <Border Grid.Column="1" Width="1" Background="#E8D5C4"/>

            <!-- ─── Right: viewer panel ──────────────────────────────────── -->
            <Grid Grid.Column="2" Background="White">

                <!-- Placeholder: no doc selected -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding HasSelectedDoc, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <md:PackIcon Kind="FileDocumentOutline" Width="48" Height="48"
                                 Foreground="#E8D5C4" HorizontalAlignment="Center"/>
                    <TextBlock Text="Chọn tài liệu từ danh sách bên trái"
                               Foreground="{StaticResource BrandTextSecondary}"
                               FontSize="14" Margin="0,12,0,0"/>
                </StackPanel>

                <!-- Loading content -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsLoadingContent, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True" Width="36" Height="36"
                                 Foreground="{StaticResource BrandAccent}"/>
                    <TextBlock Text="Đang tải nội dung..."
                               Foreground="{StaticResource BrandTextSecondary}"
                               FontSize="13" Margin="0,12,0,0"/>
                </StackPanel>

                <!-- Content error -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="24"
                            Visibility="{Binding ContentError, Converter={StaticResource StringToVisibilityConverter}}">
                    <md:PackIcon Kind="AlertCircleOutline" Width="40" Height="40"
                                 Foreground="#C62828" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ContentError, Mode=OneWay}"
                               Foreground="#C62828" FontSize="13" TextWrapping="Wrap"
                               TextAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- G-code viewer (text + toolpath toggle) -->
                <Grid Visibility="{Binding IsGcodeSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Viewer header with Text/Toolpath toggle -->
                    <Border Grid.Row="0" Background="#F5F5F5" Padding="12,6"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <md:PackIcon Kind="CodeBraces" Width="16" Height="16"
                                             Foreground="{StaticResource BrandPrimary}"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding SelectedDocLabel, Mode=OneWay}"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{StaticResource BrandText}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Toggle chip: Text ↔ Toolpath -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                <!-- Text button -->
                                <Border x:Name="TextTabBorder" CornerRadius="4,0,0,4"
                                        BorderThickness="1,1,0,1" Padding="12,4"
                                        Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource BrandPrimary}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BrandPrimary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowToolpath}" Value="True">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#BDBDBD"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding SetTextViewCommand}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="G-code" FontSize="11" FontWeight="Medium">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowToolpath}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource BrandTextSecondary}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- Toolpath button -->
                                <Border CornerRadius="0,4,4,0"
                                        BorderThickness="1,1,1,1" Padding="12,4"
                                        Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#BDBDBD"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowToolpath}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource BrandPrimary}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource BrandPrimary}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding SetToolpathViewCommand}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="VectorPolyline" Width="13" Height="13"
                                                     VerticalAlignment="Center" Margin="0,0,4,0">
                                            <md:PackIcon.Style>
                                                <Style TargetType="md:PackIcon">
                                                    <Setter Property="Foreground" Value="{StaticResource BrandTextSecondary}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowToolpath}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </md:PackIcon.Style>
                                        </md:PackIcon>
                                        <TextBlock Text="Toolpath" FontSize="11" FontWeight="Medium">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource BrandTextSecondary}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowToolpath}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- G-code text viewer -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  PanningMode="Both"
                                  kb:DragScrollBehavior.Enabled="True"
                                  Background="White"
                                  Visibility="{Binding ShowTextViewer, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <RichTextBox IsReadOnly="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="4,4,4,16"
                                     VerticalScrollBarVisibility="Disabled"
                                     HorizontalScrollBarVisibility="Disabled"
                                     IsDocumentEnabled="False"
                                     kb:GcodeViewerBehavior.Text="{Binding GcodeText, Mode=OneWay}"/>
                    </ScrollViewer>

                    <!-- Toolpath canvas -->
                    <ctrl:ToolpathCanvasControl Grid.Row="1"
                                               Moves="{Binding ToolpathMoves, Mode=OneWay}"
                                               Visibility="{Binding ShowToolpathViewer, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>

                <!-- PDF viewer (DRW, RTC, FXT, TLS, CAM...) -->
                <Grid Visibility="{Binding IsPdfViewerVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- PDF viewer header -->
                    <Border Grid.Row="0" Background="#F5F5F5" Padding="12,6"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <md:PackIcon Kind="FilePdfBox" Width="16" Height="16"
                                         Foreground="#6A1B9A"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding SelectedDocLabel, Mode=OneWay}"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource BrandText}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- WebView2 renders PDF via Edge built-in viewer.
                         Stylus flags prevent WPF from eating touch events (flick / press-hold)
                         before they reach the underlying Win32 WebView2 window. -->
                    <wv2:WebView2 x:Name="PdfWebView" Grid.Row="1"
                                  IsVisibleChanged="PdfWebView_IsVisibleChanged"
                                  Stylus.IsFlicksEnabled="False"
                                  Stylus.IsPressAndHoldEnabled="False"/>
                </Grid>

            </Grid>
        </Grid>

        <!-- ══ BOTTOM BAR ══ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E8D5C4" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Button Command="{Binding GoBackCommand}"
                        HorizontalAlignment="Left"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="44" Padding="20,0" FontSize="14"
                        BorderBrush="{StaticResource BrandPrimary}"
                        Foreground="{StaticResource BrandPrimary}"
                        Content="← Quay lại"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
