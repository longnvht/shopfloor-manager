<UserControl x:Class="ShopfloorManager.Desktop.Views.Pages.OperationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:ShopfloorManager.Desktop.Converters"
             xmlns:models="clr-namespace:ShopfloorManager.Desktop.Models">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Job info + back button -->
        <Border Grid.Row="0" Padding="0,0,0,16">
            <DockPanel>
                <Button DockPanel.Dock="Left"
                        Command="{Binding GoBackCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Quay lại danh sách Job"
                        Margin="0,0,8,0">
                    <md:PackIcon Kind="ArrowLeft" Width="20" Height="20"/>
                </Button>

                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="{Binding JobHeader}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               FontWeight="Medium"/>
                    <TextBlock Text="Chọn công đoạn để bắt đầu FAI"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <!-- Operation cards -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Operations}" Margin="0,0,8,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:PartOpDto}">
                            <Border Margin="0,0,0,12"
                                    CornerRadius="8"
                                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                                    BorderBrush="{DynamicResource MaterialDesign.Brush.DataGrid.ColumnHeader.Border}"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" Opacity="0.08" ShadowDepth="2"/>
                                </Border.Effect>

                                <Grid Margin="20,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- OP Number badge -->
                                    <Border Grid.Column="0"
                                            Width="56" Height="56"
                                            CornerRadius="8"
                                            Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="{Binding OpNumber}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="15"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- OP Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding OpTypeDisplay}"
                                                       FontWeight="Medium"
                                                       FontSize="14"/>

                                            <!-- ForJobOnly badge -->
                                            <Border Margin="8,0,0,0"
                                                    CornerRadius="4"
                                                    Padding="6,1"
                                                    Background="#FFF3E0"
                                                    Visibility="{Binding ForJobOnly,
                                                                 Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Job Only" FontSize="11"
                                                           Foreground="#E65100"/>
                                            </Border>

                                            <!-- Complete badge -->
                                            <Border Margin="8,0,0,0"
                                                    CornerRadius="4"
                                                    Padding="6,1"
                                                    Background="#E8F5E9"
                                                    Visibility="{Binding IsComplete,
                                                                 Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Hoàn thành" FontSize="11"
                                                           Foreground="#2E7D32"/>
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                                   Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding Description,
                                                                Converter={StaticResource StringToVisibilityConverter}}"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <md:PackIcon Kind="TimerOutline" Width="14" Height="14"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                                         VerticalAlignment="Center"/>
                                            <TextBlock Margin="4,0,0,0"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                                                <Run Text="Setup:"/>
                                                <Run Text="{Binding SetupTimeDisplay, Mode=OneWay}"/>
                                                <Run Text="  Gia công:"/>
                                                <Run Text="{Binding ProdTimeDisplay, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- FAI Button -->
                                    <Button Grid.Column="2"
                                            Content="Bắt đầu FAI"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            md:ButtonAssist.CornerRadius="6"
                                            IsEnabled="{Binding IsComplete,
                                                        Converter={StaticResource InverseBoolConverter}}"
                                            VerticalAlignment="Center"
                                            Padding="16,8"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Loading spinner -->
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                         IsIndeterminate="True"
                         Width="48" Height="48"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Error / empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <md:PackIcon Kind="InformationOutline"
                             Width="48" Height="48"
                             HorizontalAlignment="Center"
                             Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
