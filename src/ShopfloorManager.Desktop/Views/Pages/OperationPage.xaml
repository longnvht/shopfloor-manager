<UserControl x:Class="ShopfloorManager.Desktop.Views.Pages.OperationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:ShopfloorManager.Desktop.Models"
             xmlns:kb="clr-namespace:ShopfloorManager.Desktop.Behaviors"
             Background="{StaticResource BrandBg}">

    <UserControl.Resources>
        <!-- Full-width card item -->
        <Style x:Key="OpCardItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd"
                                Background="White"
                                CornerRadius="10"
                                BorderBrush="#E8D5C4"
                                BorderThickness="2"
                                Padding="16,14">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandPrimary}"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="3"/>
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandAccentLight}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- ══ TITLE BAR ══ -->
        <Border Grid.Row="0" Background="{StaticResource BrandPrimary}">
            <Grid Margin="16,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="CHỌN CÔNG ĐOẠN"
                               Foreground="White" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="{Binding TitleContext, Mode=OneWay}"
                               Foreground="{StaticResource BrandAccentLight}"
                               FontSize="11" Margin="0,1,0,0"/>
                </StackPanel>
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True" Width="24" Height="24"
                             HorizontalAlignment="Right"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- ══ SEARCH BAR ══ -->
        <Border Grid.Row="1" Background="White" Margin="12,6,12,0"
                CornerRadius="8" BorderBrush="#E8D5C4" BorderThickness="1.5">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         kb:KeyboardBehavior.Mode="Qwerty"
                         BorderThickness="0" FontSize="15" VerticalAlignment="Center"
                         Style="{StaticResource MaterialDesignTextBox}"
                         md:HintAssist.Hint="Tìm theo số OP hoặc tên công đoạn..."
                         md:HintAssist.IsFloating="False">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="1" Command="{Binding SearchCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource BrandPrimary}" Foreground="White"
                        Height="36" Padding="16,0" Margin="8,0,0,0" FontSize="13">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Magnify" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Tìm" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ══ OP CARD LIST (full-width) ══ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      PanningMode="VerticalFirst" Margin="12,8"
                      kb:DragScrollBehavior.Enabled="True">
            <StackPanel>
                <ListBox ItemsSource="{Binding Operations}"
                         SelectedItem="{Binding SelectedOp}"
                         ItemContainerStyle="{StaticResource OpCardItem}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         RequestBringIntoView="OnListBoxRequestBringIntoView">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:PartOpDto}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- OP Number badge -->
                                <Border Grid.Column="0"
                                        Width="60" Height="60"
                                        CornerRadius="8"
                                        Background="{StaticResource BrandPrimary}"
                                        Margin="0,0,16,0">
                                    <TextBlock Text="{Binding OpNumber, Mode=OneWay}"
                                               Foreground="White"
                                               FontWeight="Bold" FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- OP info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding OpTypeDisplay, Mode=OneWay}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{StaticResource BrandText}"/>
                                        <!-- ForJobOnly badge -->
                                        <Border Margin="8,0,0,0" CornerRadius="4" Padding="6,1"
                                                Background="#FFF3E0"
                                                Visibility="{Binding ForJobOnly, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Job Only" FontSize="10"
                                                       Foreground="#E65100"/>
                                        </Border>
                                        <!-- Complete badge -->
                                        <Border Margin="6,0,0,0" CornerRadius="4" Padding="6,1"
                                                Background="#E8F5E9"
                                                Visibility="{Binding IsComplete, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Hoàn thành" FontSize="10"
                                                       Foreground="#2E7D32"/>
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Description, Mode=OneWay}"
                                               FontSize="12"
                                               Foreground="{StaticResource BrandTextSecondary}"
                                               Margin="0,3,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <md:PackIcon Kind="TimerOutline" Width="13" Height="13"
                                                     Foreground="{StaticResource BrandTextSecondary}"
                                                     VerticalAlignment="Center"/>
                                        <TextBlock FontSize="12"
                                                   Foreground="{StaticResource BrandTextSecondary}"
                                                   Margin="4,0,0,0">
                                            <Run Text="Setup:"/>
                                            <Run Text="{Binding SetupTimeDisplay, Mode=OneWay}"/>
                                            <Run Text="  Gia công:"/>
                                            <Run Text="{Binding ProdTimeDisplay, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Arrow indicator -->
                                <md:PackIcon Grid.Column="2"
                                             Kind="ChevronRight"
                                             Width="20" Height="20"
                                             Foreground="{StaticResource BrandTextSecondary}"
                                             VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Error / empty -->
                <TextBlock Text="{Binding ErrorMessage}"
                           HorizontalAlignment="Center" Margin="0,20"
                           Foreground="{StaticResource BrandTextSecondary}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ══ BOTTOM BAR ══ -->
        <Border Grid.Row="3" Background="White"
                BorderBrush="#E8D5C4" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Button Command="{Binding GoBackCommand}"
                        HorizontalAlignment="Left"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="44" Padding="20,0" FontSize="14"
                        BorderBrush="{StaticResource BrandPrimary}"
                        Foreground="{StaticResource BrandPrimary}"
                        Content="← Quay lại"/>

                <Button Command="{Binding ConfirmCommand}"
                        HorizontalAlignment="Right"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource BrandPrimary}" Foreground="White"
                        Height="44" Padding="24,0" FontSize="14" FontWeight="Medium"
                        Content="Lựa chọn →"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
