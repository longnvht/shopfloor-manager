<UserControl x:Class="ShopfloorManager.Desktop.Views.Pages.ProductListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:ShopfloorManager.Desktop.Models">

    <UserControl.Resources>
        <!-- Màu nền theo trạng thái -->
        <SolidColorBrush x:Key="AvailableBg"   Color="#FAFAFA"/>
        <SolidColorBrush x:Key="ClaimedBg"     Color="#FFF8E1"/>
        <SolidColorBrush x:Key="InProgressBg"  Color="#FFF3E0"/>
        <SolidColorBrush x:Key="CompleteBg"    Color="#E8F5E9"/>

        <SolidColorBrush x:Key="AvailableBorder"   Color="#BDBDBD"/>
        <SolidColorBrush x:Key="ClaimedBorder"     Color="#FFC107"/>
        <SolidColorBrush x:Key="InProgressBorder"  Color="#FF6D00"/>
        <SolidColorBrush x:Key="CompleteBorder"    Color="#2E7D32"/>

        <!-- Card style theo StatusCode -->
        <Style x:Key="ProductCard" TargetType="Border">
            <Setter Property="Width" Value="170"/>
            <Setter Property="Height" Value="190"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="2.5"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: back + job info + refresh -->
        <Border Grid.Row="0" Padding="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{Binding GoBackCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Quay lại danh sách OP"
                        Margin="0,0,8,0">
                    <md:PackIcon Kind="ArrowLeft" Width="24" Height="24"/>
                </Button>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Header}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               FontWeight="Medium"/>
                    <TextBlock Text="Chọn sản phẩm để bắt đầu gia công"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Làm mới">
                    <md:PackIcon Kind="Refresh" Width="20" Height="20"/>
                </Button>
            </Grid>
        </Border>

        <!-- Product cards grid -->
        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalFirst">
                <ItemsControl ItemsSource="{Binding Products}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ProductWithSessionDto}">
                            <Border MouseLeftButtonUp="OnCardTapped">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource ProductCard}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusCode}" Value="available">
                                                <Setter Property="Background"    Value="{StaticResource AvailableBg}"/>
                                                <Setter Property="BorderBrush"   Value="{StaticResource AvailableBorder}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusCode}" Value="claimed">
                                                <Setter Property="Background"    Value="{StaticResource ClaimedBg}"/>
                                                <Setter Property="BorderBrush"   Value="{StaticResource ClaimedBorder}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusCode}" Value="inprogress">
                                                <Setter Property="Background"    Value="{StaticResource InProgressBg}"/>
                                                <Setter Property="BorderBrush"   Value="{StaticResource InProgressBorder}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusCode}" Value="complete">
                                                <Setter Property="Background"    Value="{StaticResource CompleteBg}"/>
                                                <Setter Property="BorderBrush"   Value="{StaticResource CompleteBorder}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid Margin="14,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Serial number -->
                                    <TextBlock Grid.Row="0"
                                               Text="{Binding SerialNumber}"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Foreground="#212121"/>

                                    <!-- Status icon -->
                                    <TextBlock Grid.Row="1"
                                               FontSize="36"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="available">
                                                        <Setter Property="Text" Value="○"/>
                                                        <Setter Property="Foreground" Value="#9E9E9E"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="claimed">
                                                        <Setter Property="Text" Value="🕐"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="inprogress">
                                                        <Setter Property="Text" Value="⚙"/>
                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="complete">
                                                        <Setter Property="Text" Value="✓"/>
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Status label -->
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding DisplayStatus}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="available">
                                                        <Setter Property="Foreground" Value="#757575"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="claimed">
                                                        <Setter Property="Foreground" Value="#F57F17"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="inprogress">
                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="complete">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Machine + time -->
                                    <StackPanel Grid.Row="3" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding MachineDisplay}"
                                                   FontSize="11"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#616161"
                                                   Visibility="{Binding MachineDisplay,
                                                       Converter={StaticResource StringToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding ElapsedDisplay, Mode=OneWay}"
                                                   FontSize="11"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#616161"
                                                   Visibility="{Binding ElapsedDisplay,
                                                       Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Loading -->
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                         IsIndeterminate="True" Width="48" Height="48"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
        </Grid>

        <!-- Footer: selected info + confirm button -->
        <Border Grid.Row="2" Padding="0,12,0,0"
                Visibility="{Binding SelectedProduct, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock FontWeight="Medium" FontSize="14">
                        <Run Text="Đã chọn: Serial"/>
                        <Run Text="{Binding SelectedProduct.SerialNumber, Mode=OneWay}"
                             FontWeight="Bold"/>
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1"
                        Command="{Binding SelectProductCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Height="56"
                        Padding="24,0"
                        FontSize="15"
                        Content="Bắt đầu gia công →"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
