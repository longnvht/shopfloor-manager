<UserControl x:Class="ShopfloorManager.Desktop.Views.Pages.ProductListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:ShopfloorManager.Desktop.Models"
             xmlns:kb="clr-namespace:ShopfloorManager.Desktop.Behaviors"
             Background="{StaticResource BrandBg}">

    <UserControl.Resources>
        <!-- Product card item — màu nền theo trạng thái -->
        <Style x:Key="ProductCardItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd"
                                CornerRadius="10"
                                BorderThickness="2"
                                Padding="12,10">
                            <!-- Màu nền theo StatusCode -->
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#E8D5C4"/>
                                </Style>
                            </Border.Style>
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandPrimary}"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="3"/>
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandAccentLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- ══ TITLE BAR ══ -->
        <Border Grid.Row="0" Background="{StaticResource BrandPrimary}">
            <Grid Margin="16,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding TitleContext, Mode=OneWay}"
                               Foreground="White" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="{Binding SubContext, Mode=OneWay}"
                               Foreground="{StaticResource BrandAccentLight}"
                               FontSize="11" Margin="0,1,0,0"/>
                </StackPanel>
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True" Width="24" Height="24"
                             HorizontalAlignment="Right"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- ══ SEARCH BAR ══ -->
        <Border Grid.Row="1" Background="White" Margin="12,6,12,0"
                CornerRadius="8" BorderBrush="#E8D5C4" BorderThickness="1.5">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         kb:KeyboardBehavior.Mode="Qwerty"
                         BorderThickness="0" FontSize="15" VerticalAlignment="Center"
                         Style="{StaticResource MaterialDesignTextBox}"
                         md:HintAssist.Hint="Tìm theo số serial..."
                         md:HintAssist.IsFloating="False">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="1" Command="{Binding SearchCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource BrandPrimary}" Foreground="White"
                        Height="36" Padding="16,0" Margin="8,0,0,0" FontSize="13">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Magnify" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Tìm" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ══ PRODUCT CARD GRID ══ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      PanningMode="VerticalFirst" Margin="12,8"
                      kb:DragScrollBehavior.Enabled="True">
            <StackPanel>
                <ListBox ItemsSource="{Binding Products}"
                         SelectedItem="{Binding SelectedProduct}"
                         ItemContainerStyle="{StaticResource ProductCardItem}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ProductWithSessionDto}">
                            <Grid Height="155">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Serial number -->
                                <TextBlock Grid.Row="0"
                                           Text="{Binding SerialNumber, Mode=OneWay}"
                                           FontSize="28" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#212121"/>

                                <!-- Status icon -->
                                <TextBlock Grid.Row="1"
                                           FontSize="26"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,2">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusCode}" Value="available">
                                                    <Setter Property="Text" Value="○"/>
                                                    <Setter Property="Foreground" Value="#9E9E9E"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusCode}" Value="claimed">
                                                    <Setter Property="Text" Value="◷"/>
                                                    <Setter Property="Foreground" Value="#F57F17"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusCode}" Value="inprogress">
                                                    <Setter Property="Text" Value="⚙"/>
                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusCode}" Value="complete">
                                                    <Setter Property="Text" Value="✓"/>
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Status text -->
                                <TextBlock Grid.Row="2"
                                           Text="{Binding DisplayStatus, Mode=OneWay}"
                                           FontSize="11" FontWeight="Medium"
                                           HorizontalAlignment="Center"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusCode}" Value="available">
                                                    <Setter Property="Foreground" Value="#757575"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusCode}" Value="claimed">
                                                    <Setter Property="Foreground" Value="#F57F17"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusCode}" Value="inprogress">
                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusCode}" Value="complete">
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Machine + time -->
                                <StackPanel Grid.Row="3" Margin="0,3,0,0">
                                    <TextBlock Text="{Binding MachineDisplay, Mode=OneWay}"
                                               FontSize="10" HorizontalAlignment="Center"
                                               Foreground="#9E9E9E"
                                               Visibility="{Binding MachineDisplay, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding ElapsedDisplay, Mode=OneWay}"
                                               FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{StaticResource BrandAccent}"
                                               Visibility="{Binding ElapsedDisplay, Converter={StaticResource StringToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Error / empty state -->
                <TextBlock Text="{Binding ErrorMessage}"
                           HorizontalAlignment="Center" Margin="0,20"
                           Foreground="{StaticResource BrandTextSecondary}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ══ BOTTOM BAR ══ -->
        <Border Grid.Row="3" Background="White"
                BorderBrush="#E8D5C4" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Button Command="{Binding GoBackCommand}"
                        HorizontalAlignment="Left"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="44" Padding="20,0" FontSize="14"
                        BorderBrush="{StaticResource BrandPrimary}"
                        Foreground="{StaticResource BrandPrimary}"
                        Content="← Quay lại"/>

                <Button Command="{Binding SelectProductCommand}"
                        HorizontalAlignment="Right"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource BrandPrimary}" Foreground="White"
                        Height="44" Padding="24,0" FontSize="14" FontWeight="Medium">
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Lựa chọn →"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsViewMode}" Value="True">
                                        <Setter Property="Text" Value="Xem sản phẩm →"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
