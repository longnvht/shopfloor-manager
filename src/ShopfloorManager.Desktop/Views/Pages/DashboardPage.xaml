<UserControl x:Class="ShopfloorManager.Desktop.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:ShopfloorManager.Desktop.Models"
             Background="{StaticResource BrandBg}">

    <UserControl.Resources>
        <!-- Card nền trắng, bo góc, shadow nhẹ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2" Color="#6D3B1A"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label nhỏ trên thẻ -->
        <Style x:Key="CardLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource BrandAccent}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Dòng stat: label + value -->
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource BrandTextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrandText}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- OEE metric tile: big % + label + thin bar -->
        <Style x:Key="OeeLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource BrandTextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <!-- Utility button -->
        <Style x:Key="UtilBtn" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="White" CornerRadius="10"
                                BorderBrush="#E8D5C4" BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandAccentLight}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandAccent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>   <!-- Title Bar -->
            <RowDefinition Height="Auto"/> <!-- Machine + Operator -->
            <RowDefinition Height="Auto"/> <!-- Work Info -->
            <RowDefinition Height="*"/>    <!-- Tiện ích -->
        </Grid.RowDefinitions>

        <!-- ══════════════ TITLE BAR ══════════════ -->
        <Border Grid.Row="0" Background="{StaticResource BrandPrimary}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <md:PackIcon Kind="Factory" Width="24" Height="24"
                                 Foreground="{StaticResource BrandAccentLight}"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="SHOPFLOOR MANAGER"
                               Foreground="White" FontWeight="Bold" FontSize="15"
                               VerticalAlignment="Center"/>
                    <!-- Mode toggle chip — always visible, click to toggle (disabled when forced View Mode) -->
                    <Border CornerRadius="4" Padding="8,3"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleModeCommand}"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="#60FFFFFF"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsViewMode, Mode=OneWay}" Value="True">
                                        <Setter Property="Background" Value="#FF8F00"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CanSwitchMode, Mode=OneWay}" Value="False">
                                        <Setter Property="Cursor" Value="Arrow"/>
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Width="13" Height="13"
                                         VerticalAlignment="Center" Margin="0,0,4,0">
                                <md:PackIcon.Style>
                                    <Style TargetType="md:PackIcon">
                                        <Setter Property="Kind" Value="EyeOffOutline"/>
                                        <Setter Property="Foreground" Value="#80FFFFFF"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsViewMode, Mode=OneWay}" Value="True">
                                                <Setter Property="Kind" Value="EyeOutline"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </md:PackIcon.Style>
                            </md:PackIcon>
                            <TextBlock FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="VIEW"/>
                                        <Setter Property="Foreground" Value="#80FFFFFF"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsViewMode, Mode=OneWay}" Value="True">
                                                <Setter Property="Text" Value="VIEW MODE"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentTime, Mode=OneWay}"
                           Foreground="{StaticResource BrandAccentLight}"
                           FontSize="17" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <Button Grid.Column="3"
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White" Height="36" Padding="10,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Logout" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Đăng xuất" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ══════════════ MACHINE + OPERATOR CARDS ══════════════ -->
        <Grid Grid.Row="1" Margin="12,8,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Machine Card -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="36" Height="36" CornerRadius="6"
                                Background="{StaticResource BrandAccentLight}" Margin="0,0,10,0">
                            <md:PackIcon Kind="Monitor" Width="22" Height="22"
                                         Foreground="{StaticResource BrandAccent}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding MachineCode, Mode=OneWay}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource BrandText}"/>
                            <TextBlock Text="{Binding MachineName, Mode=OneWay}"
                                       FontSize="11" Foreground="{StaticResource BrandTextSecondary}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#F5E6D3" Margin="0,0,0,10"/>

                    <!-- OEE metrics: Availability + Quality side by side -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Availability tile -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="AVAILABILITY" Style="{StaticResource OeeLabel}"/>
                            <TextBlock FontSize="22" FontWeight="Bold" Margin="0,0,0,4"
                                       Foreground="{Binding AvailabilityBrush, Mode=OneWay}">
                                <Run Text="{Binding AvailabilityPct, Mode=OneWay, StringFormat='{}{0:F0}'}"/>
                                <Run Text="%" FontSize="14"/>
                            </TextBlock>
                            <ProgressBar Value="{Binding AvailabilityPct, Mode=OneWay}"
                                         Maximum="100" Height="6"
                                         Foreground="{Binding AvailabilityBrush, Mode=OneWay}"
                                         Background="#E8D5C4" BorderThickness="0"/>
                            <TextBlock Text="{Binding ActiveTimeDisplay, Mode=OneWay}"
                                       FontSize="10" FontFamily="Consolas"
                                       Foreground="{StaticResource BrandTextSecondary}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#F5E6D3" Width="1" Margin="0,0,0,0"/>

                        <!-- Quality tile -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="QUALITY" Style="{StaticResource OeeLabel}"/>
                            <TextBlock FontSize="22" FontWeight="Bold" Margin="0,0,0,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource BrandTextSecondary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasQualityData, Mode=OneWay}" Value="True">
                                                <Setter Property="Foreground" Value="{Binding QualityBrush, Mode=OneWay}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="{Binding QualityPct, Mode=OneWay, StringFormat='{}{0:F0}'}"/>
                                <Run Text="%" FontSize="14"/>
                            </TextBlock>
                            <ProgressBar Value="{Binding QualityPct, Mode=OneWay}"
                                         Maximum="100" Height="6"
                                         Foreground="{Binding QualityBrush, Mode=OneWay}"
                                         Background="#E8D5C4" BorderThickness="0"
                                         Visibility="{Binding HasQualityData, Mode=OneWay,
                                             Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="Chưa có dữ liệu hôm nay"
                                       FontSize="10" Foreground="{StaticResource BrandTextSecondary}"
                                       Margin="0,3,0,0"
                                       Visibility="{Binding HasQualityData, Mode=OneWay,
                                           Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#F5E6D3" Margin="0,0,0,8"/>

                    <!-- Compact stats row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="22"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mở máy" Style="{StaticResource StatLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding UptimeDisplay, Mode=OneWay}" Style="{StaticResource StatValue}" FontFamily="Consolas"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="SP hoàn thành hôm nay" Style="{StaticResource StatLabel}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProductsCompletedDisplay, Mode=OneWay}" Style="{StaticResource StatValue}" FontSize="15" Foreground="#2E7D32"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Operator Card -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Width="36" Height="36" CornerRadius="18"
                                Background="{StaticResource BrandAccentLight}" Margin="0,0,10,0">
                            <md:PackIcon Kind="AccountCircle" Width="22" Height="22"
                                         Foreground="{StaticResource BrandPrimary}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserDisplayName, Mode=OneWay}"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource BrandText}"/>
                            <TextBlock Text="{Binding UserRole, Mode=OneWay}"
                                       FontSize="11" Foreground="{StaticResource BrandTextSecondary}"/>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#F5E6D3" Margin="0,0,0,10"/>

                    <!-- Stats grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Check-in" Style="{StaticResource StatLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CheckInDisplay, Mode=OneWay}" Style="{StaticResource StatValue}" FontFamily="Consolas"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Thời gian làm việc" Style="{StaticResource StatLabel}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WorkDuration, Mode=OneWay}" Style="{StaticResource StatValue}" FontFamily="Consolas" Foreground="{StaticResource BrandAccent}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Thời gian nhàn rỗi" Style="{StaticResource StatLabel}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding OperatorIdleDisplay, Mode=OneWay}" Style="{StaticResource StatValue}" FontFamily="Consolas" Foreground="{StaticResource BrandTextSecondary}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="SP đã tạo ra" Style="{StaticResource StatLabel}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ProductsCreatedDisplay, Mode=OneWay}" Style="{StaticResource StatValue}" FontSize="16" Foreground="#2E7D32"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════ WORK INFO CARD ══════════════ -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="12,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Work Info -->
                <Grid Grid.Row="0" Grid.Column="0">
                    <!-- EMPTY STATE -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding HasWork, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <md:PackIcon Kind="ClipboardOutline" Width="32" Height="32"
                                     Foreground="#BCAAA4" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Chưa có công việc"
                                       FontSize="15" FontWeight="Medium"
                                       Foreground="{StaticResource BrandTextSecondary}"/>
                            <TextBlock Text="Nhấn 'Chọn Job' để bắt đầu"
                                       FontSize="12" Foreground="#BCAAA4"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- HAS WORK STATE -->
                    <Grid Visibility="{Binding HasWork, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Job -->
                        <StackPanel Grid.Column="0" Margin="0,0,24,0">
                            <TextBlock Text="JOB" Style="{StaticResource CardLabel}"/>
                            <TextBlock Text="{Binding JobNumber, Mode=OneWay}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource BrandText}"/>
                            <TextBlock Text="{Binding PartDisplay, Mode=OneWay}"
                                       FontSize="11" Foreground="{StaticResource BrandTextSecondary}"
                                       MaxWidth="160" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- OP -->
                        <StackPanel Grid.Column="1" Margin="0,0,24,0"
                                    Visibility="{Binding OpDisplay, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="CÔNG ĐOẠN" Style="{StaticResource CardLabel}"/>
                            <TextBlock Text="{Binding OpDisplay, Mode=OneWay}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandText}"/>
                        </StackPanel>

                        <!-- Serial -->
                        <StackPanel Grid.Column="2" Margin="0,0,24,0"
                                    Visibility="{Binding SerialDisplay, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="SẢN PHẨM" Style="{StaticResource CardLabel}"/>
                            <TextBlock Text="{Binding SerialDisplay, Mode=OneWay}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource BrandText}"/>
                        </StackPanel>

                        <!-- Status + Timer -->
                        <StackPanel Grid.Column="3"
                                    Visibility="{Binding HasSession, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="TRẠNG THÁI" Style="{StaticResource CardLabel}"/>
                            <TextBlock Text="{Binding StatusDisplay, Mode=OneWay}"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource BrandAccent}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        Visibility="{Binding CanStop, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <md:PackIcon Kind="TimerOutline" Width="14" Height="14"
                                             Foreground="{StaticResource BrandAccent}"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ElapsedTime, Mode=OneWay}"
                                           FontSize="14" FontFamily="Consolas" FontWeight="Bold"
                                           Foreground="{StaticResource BrandAccent}"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- Job Progress bar (Row 1, span 2 columns) -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        BorderBrush="#F5E6D3" BorderThickness="0,1,0,0"
                        Margin="0,10,0,-4" Padding="0,8,0,0"
                        Visibility="{Binding HasJobProgress, Mode=OneWay,
                            Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TIẾN ĐỘ JOB" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource BrandAccent}" Margin="0,0,0,4"/>
                            <ProgressBar Value="{Binding JobProgressPct, Mode=OneWay}"
                                         Maximum="100" Height="8"
                                         Foreground="#2E7D32" Background="#E8D5C4"
                                         BorderThickness="0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding JobProgressText, Mode=OneWay}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandText}"
                                   VerticalAlignment="Bottom" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Right: Action Buttons -->
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0,0,0">

                    <!-- Chọn Job (chỉ hiện khi chưa có job và không đang force-finish) -->
                    <Button Command="{Binding SelectJobCommand}"
                            Visibility="{Binding ShowSelectJobButton, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource BrandPrimary}" Foreground="White"
                            Height="48" Padding="16,0" FontSize="13"
                            Content="+ Chọn Job"/>

                    <!-- Tiếp tục (có job, không session, không force-finish) -->
                    <Button Command="{Binding TapWorkInfoCommand}"
                            Visibility="{Binding ShowNavigateButton, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="48" Padding="14,0" FontSize="13"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ChevronRight" VerticalAlignment="Center"/>
                            <TextBlock Text="Tiếp tục" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Bắt đầu (claimed, not started) -->
                    <Button Command="{Binding StartCommand}"
                            Visibility="{Binding CanStart, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource BrandAccent}" Foreground="White"
                            Height="52" Padding="16,0" FontSize="14" FontWeight="Bold"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Play" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Bắt đầu" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Kết thúc (in progress) -->
                    <Button Command="{Binding StopCommand}"
                            Visibility="{Binding ShowStopButton, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#C62828" Foreground="White"
                            Height="52" Padding="16,0" FontSize="14" FontWeight="Bold">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Stop" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Kết thúc" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Kết thúc phiên (Leader/Admin force-finish) -->
                    <StackPanel Orientation="Vertical" Margin="8,0,0,0"
                                Visibility="{Binding CanForceFinish, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock FontSize="10" Foreground="#FF8F00" TextAlignment="Center" Margin="0,0,0,4">
                            <Run Text="⚠ Bởi:"/>
                            <Run Text="{Binding IncomingOwnerName, Mode=OneWay}" FontWeight="Bold"/>
                        </TextBlock>
                        <Button Command="{Binding ForceFinishCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#E65100" Foreground="White"
                                Height="44" Padding="14,0" FontSize="13" FontWeight="Bold">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ShieldRemoveOutline" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Kết thúc phiên" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════ DANH SÁCH TIỆN ÍCH ══════════════ -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="12,4,12,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="TIỆN ÍCH" Style="{StaticResource CardLabel}"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              PanningMode="VerticalFirst">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Shortcuts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ShortcutItem}">
                                    <Button Command="{Binding Command}"
                                            IsEnabled="{Binding IsEnabled}"
                                            Style="{StaticResource UtilBtn}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <md:PackIcon Kind="{Binding IconKind}"
                                                         Width="28" Height="28"
                                                         Foreground="{StaticResource BrandPrimary}"
                                                         HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{StaticResource BrandText}"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       MaxWidth="108"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty shortcuts -->
                        <TextBlock Text="Chọn Job để xem các tiện ích"
                                   FontSize="12" Foreground="#BCAAA4"
                                   Margin="8,4"
                                   Visibility="{Binding Shortcuts.Count,
                                       Converter={StaticResource ZeroToVisibilityConverter}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ══════════════ REALTIME NOTIFICATION (SignalR) ══════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                Margin="16,0,16,16" CornerRadius="8" Padding="14,10"
                Background="#B71C1C">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SignalRNotification, Mode=OneWay}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding HasSignalRNotification, Mode=OneWay}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="AlertCircleOutline" Width="20" Height="20"
                             Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding SignalRNotification, Mode=OneWay}"
                           Foreground="White" FontSize="13" FontWeight="Medium"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
