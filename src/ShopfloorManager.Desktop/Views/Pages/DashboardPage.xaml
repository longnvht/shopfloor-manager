<UserControl x:Class="ShopfloorManager.Desktop.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:ShopfloorManager.Desktop.Models"
             Background="{StaticResource BrandBg}">

    <UserControl.Resources>
        <!-- Card base style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" Opacity="0.10" ShadowDepth="2" Color="#6D3B1A"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shortcut button style -->
        <Style x:Key="ShortcutBtn" TargetType="Button">
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="130"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#EFEBE9"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandAccentLight}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandAccent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Work Info card — clickable -->
        <Style x:Key="WorkCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>  <!-- Top bar -->
            <RowDefinition Height="*"/>   <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ===== TOP BAR ===== -->
        <Border Grid.Row="0" Background="{StaticResource BrandPrimary}">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <md:PackIcon Kind="Factory" Width="28" Height="28"
                                 Foreground="{StaticResource BrandAccentLight}"
                                 VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="SHOPFLOOR MANAGER"
                               Foreground="White" FontWeight="Bold"
                               FontSize="16" VerticalAlignment="Center"
                              />
                </StackPanel>

                <!-- Clock -->
                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentTime, Mode=OneWay}"
                           Foreground="{StaticResource BrandAccentLight}"
                           FontSize="18" FontFamily="Consolas"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <!-- Logout -->
                <Button Grid.Column="3"
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White"
                        Height="40" Padding="12,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Logout" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Đăng xuất" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===== CONTENT ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="VerticalFirst">
            <Grid Margin="24,20,24,24" MaxWidth="1400">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- Left column: Employee + Work Info -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">

                    <!-- === EMPLOYEE + MACHINE ROW === -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Employee card -->
                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,16">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{StaticResource BrandPrimaryColor}"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>2,0,0,0</Border.BorderThickness>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="52" Height="52" CornerRadius="26"
                                        Background="{StaticResource BrandAccentLight}"
                                        Margin="0,0,16,0">
                                    <md:PackIcon Kind="AccountCircle" Width="34" Height="34"
                                                 Foreground="{StaticResource BrandPrimary}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding UserDisplayName}"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="{StaticResource BrandText}"/>
                                    <TextBlock Text="{Binding UserRole}"
                                               FontSize="12"
                                               Foreground="{StaticResource BrandTextSecondary}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Machine card -->
                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,16">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{StaticResource BrandAccentColor}"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>2,0,0,0</Border.BorderThickness>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="52" Height="52" CornerRadius="8"
                                        Background="{StaticResource BrandAccentLight}"
                                        Margin="0,0,16,0">
                                    <md:PackIcon Kind="Monitor" Width="30" Height="30"
                                                 Foreground="{StaticResource BrandAccent}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding MachineCode}"
                                               FontSize="17" FontWeight="Bold"
                                               Foreground="{StaticResource BrandText}"/>
                                    <TextBlock Text="{Binding MachineName}"
                                               FontSize="11"
                                               Foreground="{StaticResource BrandTextSecondary}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="180"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- === WORK INFO CARD === -->
                    <Border Style="{StaticResource WorkCard}"
                            MouseLeftButtonUp="OnWorkCardTapped">
                        <!-- Grid wrapper — Border chỉ nhận 1 child -->
                        <Grid>

                        <!-- STATE: EMPTY -->
                        <Grid Visibility="{Binding ShowEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="0,20">
                                <md:PackIcon Kind="ClipboardOutline" Width="56" Height="56"
                                             Foreground="#BCAAA4"
                                             HorizontalAlignment="Center"/>
                                <TextBlock Text="Chưa có công việc"
                                           FontSize="18" FontWeight="Medium"
                                           Foreground="{StaticResource BrandTextSecondary}"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,4"/>
                                <TextBlock Text="Nhấn để chọn Job và bắt đầu sản xuất"
                                           FontSize="13"
                                           Foreground="#A1887F"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,20"/>
                                <Button Content="+ Chọn Job"
                                        Command="{Binding SelectJobCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource BrandPrimary}"
                                        Foreground="White"
                                        HorizontalAlignment="Center"
                                        Height="52" Padding="24,0" FontSize="14"/>
                            </StackPanel>
                        </Grid>

                        <!-- STATE: HAS JOB -->
                        <Grid Visibility="{Binding ShowHasJob, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="CÔNG VIỆC" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource BrandAccent}"/>
                                <Separator Margin="0,8" Background="#EFEBE9"/>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding JobNumber}"
                                                   FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource BrandText}"/>
                                        <TextBlock Text="{Binding PartDisplay}"
                                                   FontSize="14" Foreground="{StaticResource BrandTextSecondary}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="Giao: " FontSize="12" Foreground="#A1887F"/>
                                            <TextBlock Text="{Binding ShipByDisplay, Mode=OneWay}"
                                                       FontSize="12" Foreground="#A1887F"/>
                                            <TextBlock Text="   Số lượng: " FontSize="12" Foreground="#A1887F"/>
                                            <TextBlock Text="{Binding RunQtyDisplay, Mode=OneWay}"
                                                       FontSize="12" Foreground="#A1887F"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource BrandAccentLight}"
                                            CornerRadius="8" Padding="12,8" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="ChevronRight" Foreground="{StaticResource BrandAccent}"
                                                         VerticalAlignment="Center"/>
                                            <TextBlock Text="Chọn OP" FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource BrandAccent}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- STATE: HAS OP -->
                        <Grid Visibility="{Binding ShowHasOp, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="CÔNG VIỆC" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource BrandAccent}"/>
                                <Separator Margin="0,8" Background="#EFEBE9"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="14" Foreground="{StaticResource BrandTextSecondary}">
                                            <Run FontWeight="Bold" Foreground="{StaticResource BrandText}"
                                                 Text="{Binding JobNumber}"/>
                                            <Run Text=" — "/>
                                            <Run Text="{Binding PartDisplay, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding OpDisplay, Mode=OneWay}"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource BrandText}"
                                                   Margin="0,6,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <md:PackIcon Kind="TimerOutline" Width="14" Height="14"
                                                         Foreground="#A1887F" VerticalAlignment="Center"/>
                                            <TextBlock FontSize="12" Foreground="#A1887F" Margin="4,0,0,0">
                                                <Run Text="Setup: "/>
                                                <Run Text="{Binding SetupDisplay, Mode=OneWay}"/>
                                                <Run Text="   Gia công: "/>
                                                <Run Text="{Binding ProdDisplay, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="Sản phẩm: chưa chọn"
                                                   FontSize="13" Foreground="#BCAAA4" Margin="0,8,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource BrandAccentLight}"
                                            CornerRadius="8" Padding="12,8" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="ChevronRight" Foreground="{StaticResource BrandAccent}"
                                                         VerticalAlignment="Center"/>
                                            <TextBlock Text="Chọn SN" FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource BrandAccent}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- STATE: WIP -->
                        <Border Visibility="{Binding ShowWip, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Background="{StaticResource BrandAccentLight}"
                                CornerRadius="10" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Background="{StaticResource BrandAccent}" CornerRadius="4"
                                                Padding="8,2" Margin="0,0,10,0">
                                            <TextBlock Text="⚙ ĐANG GIA CÔNG" FontSize="11" FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="{Binding SessionMachine, Mode=OneWay}"
                                                   FontSize="12" Foreground="{StaticResource BrandTextSecondary}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock FontSize="14" Foreground="{StaticResource BrandTextSecondary}">
                                        <Run FontWeight="Bold" Foreground="{StaticResource BrandText}"
                                             Text="{Binding JobNumber, Mode=OneWay}"/>
                                        <Run Text=" › "/>
                                        <Run Text="{Binding OpDisplay, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="26" FontWeight="Bold"
                                               Foreground="{StaticResource BrandText}" Margin="0,4">
                                        <Run Text="SN "/>
                                        <Run Text="{Binding SerialDisplay, Mode=OneWay}"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="TimerOutline" Width="16" Height="16"
                                                     Foreground="{StaticResource BrandAccent}"
                                                     VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ElapsedTime, Mode=OneWay}"
                                                   FontSize="18" FontFamily="Consolas" FontWeight="Bold"
                                                   Foreground="{StaticResource BrandAccent}"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Command="{Binding GoToFaiCommand}"
                                        Background="{StaticResource BrandPrimary}"
                                        Foreground="White"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Height="60" Padding="20,0"
                                        VerticalAlignment="Center"
                                        FontSize="14">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="ChevronRight" VerticalAlignment="Center"/>
                                        <TextBlock Text="Vào FAI" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- STATE: COMPLETE -->
                        <Grid Visibility="{Binding ShowComplete, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#2E7D32" CornerRadius="4" Padding="8,2">
                                        <TextBlock Text="✓ HOÀN THÀNH" FontSize="11" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock FontSize="14" Foreground="{StaticResource BrandTextSecondary}">
                                    <Run FontWeight="Bold" Foreground="{StaticResource BrandText}"
                                         Text="{Binding JobNumber, Mode=OneWay}"/>
                                    <Run Text=" › SN "/>
                                    <Run Text="{Binding SerialDisplay, Mode=OneWay}"/>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="Chọn sản phẩm tiếp theo"
                                            Command="{Binding GoToProductsCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Height="48" Padding="16,0" Margin="0,0,12,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        </Grid><!-- end wrapper -->
                    </Border>

                </StackPanel>

                <!-- Right column: Shortcuts -->
                <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="TIỆN ÍCH" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource BrandAccent}"
                                   Margin="0,0,0,16"/>

                        <ItemsControl ItemsSource="{Binding Shortcuts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ShortcutItem}">
                                    <Button Command="{Binding Command}"
                                            IsEnabled="{Binding IsEnabled}"
                                            Style="{StaticResource ShortcutBtn}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <md:PackIcon x:Name="icon"
                                                         Kind="{Binding IconKind}"
                                                         Width="36" Height="36"
                                                         Foreground="{StaticResource BrandPrimary}"
                                                         HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12" FontWeight="Medium"
                                                       Foreground="{StaticResource BrandText}"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       MaxWidth="120"
                                                       Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty shortcuts state -->
                        <TextBlock Text="Chọn Job để xem các tùy chọn"
                                   FontSize="12" Foreground="#BCAAA4"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="0,8"
                                   Visibility="{Binding Shortcuts.Count,
                                       Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
