<UserControl x:Class="ShopfloorManager.Desktop.Views.Pages.JobListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:ShopfloorManager.Desktop.Converters"
             xmlns:models="clr-namespace:ShopfloorManager.Desktop.Models"
             Background="{StaticResource BrandBg}">

    <UserControl.Resources>
        <conv:BoolToRedBrushConverter x:Key="BoolToRedBrushConverter"/>

        <!-- ListBoxItem style: loại bỏ highlight mặc định, card tự xử lý selected -->
        <Style x:Key="CardItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd"
                                Background="White"
                                CornerRadius="10"
                                BorderBrush="#E8D5C4"
                                BorderThickness="2"
                                Padding="14,12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrandPrimary}"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="3"/>
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrandAccentLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- ══ TITLE BAR ══ -->
        <Border Grid.Row="0" Background="{StaticResource BrandPrimary}">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <md:PackIcon Kind="Factory" Width="20" Height="20"
                                 Foreground="{StaticResource BrandAccentLight}"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding TitleContext, Mode=OneWay}"
                               Foreground="White" FontWeight="Bold" FontSize="15"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Loading indicator -->
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True" Width="24" Height="24"
                             HorizontalAlignment="Right"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- ══ JOB CARD GRID ══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      PanningMode="VerticalFirst" Margin="12,8">
            <StackPanel>
                <ListBox ItemsSource="{Binding Jobs}"
                         SelectedItem="{Binding SelectedJob}"
                         ItemContainerStyle="{StaticResource CardItem}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:JobSummaryDto}">
                            <Grid Height="160">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Job Number -->
                                <TextBlock Grid.Row="0"
                                           Text="{Binding JobNumber, Mode=OneWay}"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="{StaticResource BrandText}"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Part info -->
                                <StackPanel Grid.Row="1" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding PartNumber, Mode=OneWay}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{StaticResource BrandTextSecondary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource BrandTextSecondary}"
                                               Margin="0,2,0,0">
                                        <Run Text="Rev"/>
                                        <Run Text="{Binding RevCode, Mode=OneWay}" FontWeight="Medium"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding RunQty, Mode=OneWay}"/>
                                        <Run Text="pcs"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Ship date + overdue -->
                                <Border Grid.Row="2" CornerRadius="4" Padding="6,2"
                                        HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F5F5F5"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource BrandTextSecondary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                        <Setter Property="FontWeight" Value="Medium"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="{Binding ShipByDisplay, Mode=OneWay}"/>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Pagination -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8">
                    <Button Command="{Binding PrevPageCommand}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Width="40" Height="40">
                        <md:PackIcon Kind="ChevronLeft"/>
                    </Button>
                    <TextBlock VerticalAlignment="Center" Margin="8,0" FontSize="13"
                               Foreground="{StaticResource BrandTextSecondary}">
                        <Run Text="Trang"/>
                        <Run Text="{Binding CurrentPage, Mode=OneWay}" FontWeight="Bold"/>
                        <Run Text="/"/>
                        <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                        <Run Text="  ·  "/>
                        <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                        <Run Text="jobs"/>
                    </TextBlock>
                    <Button Command="{Binding NextPageCommand}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Width="40" Height="40">
                        <md:PackIcon Kind="ChevronRight"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- ══ BOTTOM BAR ══ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E8D5C4" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Button Command="{Binding GoBackCommand}"
                        HorizontalAlignment="Left"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="44" Padding="20,0" FontSize="14"
                        BorderBrush="{StaticResource BrandPrimary}"
                        Foreground="{StaticResource BrandPrimary}"
                        Content="← Quay lại"/>

                <Button Command="{Binding OpenSelectedJobCommand}"
                        HorizontalAlignment="Right"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource BrandPrimary}" Foreground="White"
                        Height="44" Padding="24,0" FontSize="14" FontWeight="Medium"
                        Content="Lựa chọn →"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
