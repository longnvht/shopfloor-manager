<UserControl x:Class="ShopfloorManager.Desktop.Views.Pages.JobListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:ShopfloorManager.Desktop.Converters"
             xmlns:models="clr-namespace:ShopfloorManager.Desktop.Models"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <conv:BoolToRedBrushConverter x:Key="BoolToRedBrushConverter"/>

        <Style x:Key="OverdueRowStyle" TargetType="DataGridRow">
            <Setter Property="Background"
                    Value="{Binding IsOverdue, Converter={StaticResource BoolToRedBrushConverter}}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Padding="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         md:HintAssist.Hint="Tìm theo số Job hoặc mã Part..."
                         md:HintAssist.IsFloating="False"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         MaxWidth="400"
                         HorizontalAlignment="Left"
                         md:TextFieldAssist.HasClearButton="True">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- Show completed toggle -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0">
                    <ToggleButton IsChecked="{Binding ShowCompleted}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                    <TextBlock Text="Hiện đã hoàn thành"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Search button -->
                <Button Grid.Column="2"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Content="Tìm kiếm"
                        Margin="0,0,8,0"/>

                <!-- Refresh button -->
                <Button Grid.Column="3"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        ToolTip="Làm mới">
                    <md:PackIcon Kind="Refresh"/>
                </Button>
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Grid Grid.Row="1">
            <DataGrid ItemsSource="{Binding Jobs}"
                      SelectedItem="{Binding SelectedJob}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      RowStyle="{StaticResource OverdueRowStyle}"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      md:DataGridAssist.ColumnHeaderPadding="16 8 16 8">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Số Job"
                                        Binding="{Binding JobNumber}"
                                        Width="140"
                                        FontWeight="Medium"/>

                    <DataGridTextColumn Header="Part Number"
                                        Binding="{Binding PartNumber}"
                                        Width="160"/>

                    <DataGridTextColumn Header="Rev"
                                        Binding="{Binding RevCode}"
                                        Width="60"/>

                    <DataGridTextColumn Header="Routing Rev"
                                        Binding="{Binding RoutingRevCode}"
                                        Width="90"/>

                    <DataGridTextColumn Header="SL"
                                        Binding="{Binding RunQty}"
                                        Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- ShipBy với màu overdue -->
                    <DataGridTemplateColumn Header="Ngày giao" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:JobSummaryDto}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <md:PackIcon Kind="AlertCircle"
                                                 Foreground="#D32F2F"
                                                 Width="16" Height="16"
                                                 Margin="0,0,4,0"
                                                 Visibility="{Binding IsOverdue, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding ShipByDisplay}"
                                               Foreground="{Binding IsOverdue, Converter={StaticResource BoolToRedBrushConverter}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status badge -->
                    <DataGridTemplateColumn Header="Trạng thái" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:JobSummaryDto}">
                                <Border CornerRadius="10"
                                        Padding="8,2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsComplete}" Value="False">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsComplete}" Value="False">
                                                        <Setter Property="Foreground" Value="#1565C0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Loading spinner -->
            <Border Background="#80FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Width="48" Height="48"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
            </Border>

            <!-- Empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <md:PackIcon Kind="AlertCircleOutline"
                             Width="48" Height="48"
                             Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                             HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Pagination footer -->
        <Border Grid.Row="2" Padding="0,12,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                    <Run Text="Tổng:"/>
                    <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                    <Run Text="job —"/>
                    <Run Text="Trang"/>
                    <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                    <Run Text="/"/>
                    <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                </TextBlock>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding PrevPageCommand}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Trang trước">
                        <md:PackIcon Kind="ChevronLeft"/>
                    </Button>
                    <Button Command="{Binding NextPageCommand}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Trang sau">
                        <md:PackIcon Kind="ChevronRight"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
