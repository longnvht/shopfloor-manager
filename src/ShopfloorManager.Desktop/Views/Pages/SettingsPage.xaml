<UserControl x:Class="ShopfloorManager.Desktop.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandBg}">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" Opacity="0.08" ShadowDepth="2" Color="#6D3B1A"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource BrandAccent}"/>
            <Setter Property="Margin" Value="2,12,0,6"/>
        </Style>

        <Style x:Key="FieldLbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource BrandTextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InfoLbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource BrandTextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InfoVal" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrandText}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- ══ TITLE BAR ══ -->
        <Border Grid.Row="0" Background="{StaticResource BrandPrimary}">
            <Grid Margin="16,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="CÀI ĐẶT"
                               Foreground="White" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="Cấu hình hệ thống"
                               Foreground="{StaticResource BrandAccentLight}"
                               FontSize="11" Margin="0,1,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ CONTENT ══ -->
        <ScrollViewer Grid.Row="1" Padding="16,4,16,12" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ─ Section: Kết nối API ─ -->
                <TextBlock Text="KẾT NỐI API" Style="{StaticResource SectionHead}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="URL máy chủ API" Style="{StaticResource FieldLbl}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                     md:HintAssist.Hint="http://192.168.0.100:5066"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Content="Kiểm tra"
                                    Command="{Binding TestConnectionCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource BrandPrimary}"
                                    BorderBrush="{StaticResource BrandPrimary}"
                                    Width="110"/>
                        </Grid>

                        <!-- Status after test -->
                        <TextBlock Margin="0,8,0,0" FontSize="13" TextWrapping="Wrap"
                                   Text="{Binding ConnectionStatus, Mode=OneWay}"
                                   Visibility="{Binding ConnectionStatus, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource BrandTextSecondary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TestPassed}" Value="True">
                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TestPassed}" Value="False">
                                            <Setter Property="Foreground" Value="#C62828"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ─ Section: Cấu hình máy ─ -->
                <TextBlock Text="CẤU HÌNH MÁY" Style="{StaticResource SectionHead}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Mã máy (Machine Code)" Style="{StaticResource FieldLbl}"/>
                        <TextBox Text="{Binding MachineCode, UpdateSourceTrigger=PropertyChanged}"
                                 md:HintAssist.Hint="ví dụ: 3100L"
                                 Margin="0,0,0,12"/>
                        <TextBlock Text="Tên máy (Machine Name)" Style="{StaticResource FieldLbl}"/>
                        <TextBox Text="{Binding MachineName, UpdateSourceTrigger=PropertyChanged}"
                                 md:HintAssist.Hint="ví dụ: LONG LATHE MACHINE"/>
                    </StackPanel>
                </Border>

                <!-- ─ Section: Thông tin ─ -->
                <TextBlock Text="THÔNG TIN" Style="{StaticResource SectionHead}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Phiên bản ứng dụng" Style="{StaticResource InfoLbl}"/>
                            <TextBlock Text="{Binding AppVersion, Mode=OneWay}" Style="{StaticResource InfoVal}"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Nền tảng" Style="{StaticResource InfoLbl}"/>
                            <TextBlock Text=".NET 9 / WPF" Style="{StaticResource InfoVal}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Save status message -->
                <TextBlock Margin="2,4,0,0" FontSize="13" TextWrapping="Wrap"
                           Text="{Binding SaveStatus, Mode=OneWay}"
                           Visibility="{Binding SaveStatus, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource BrandAccent}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SavePassed}" Value="True">
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SavePassed}" Value="False">
                                    <Setter Property="Foreground" Value="#C62828"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>
        </ScrollViewer>

        <!-- ══ BOTTOM BAR ══ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E8D5C4" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Button Content="← Trở về"
                        Command="{Binding BackCommand}"
                        HorizontalAlignment="Left"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{StaticResource BrandPrimary}"
                        BorderBrush="{StaticResource BrandPrimary}"
                        Width="130"/>
                <Button Content="Lưu cấu hình"
                        Command="{Binding SaveCommand}"
                        HorizontalAlignment="Right"
                        Background="{StaticResource BrandPrimary}"
                        Foreground="White"
                        Width="150"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
