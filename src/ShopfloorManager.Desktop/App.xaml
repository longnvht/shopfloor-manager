<Application x:Class="ShopfloorManager.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:ShopfloorManager.Desktop.Converters"
             xmlns:vm="clr-namespace:ShopfloorManager.Desktop.ViewModels"
             xmlns:views="clr-namespace:ShopfloorManager.Desktop.Views"
             xmlns:pages="clr-namespace:ShopfloorManager.Desktop.Views.Pages">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <md:BundledTheme BaseTheme="Light" PrimaryColor="BlueGrey" SecondaryColor="Cyan"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <conv:BoolToRedBrushConverter x:Key="BoolToRedBrushConverter"/>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

            <!-- ===== TOUCH-FRIENDLY GLOBAL STYLES ===== -->

            <!-- Button: min height 56 cho touch -->
            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="MinHeight" Value="56"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="16,0"/>
            </Style>

            <!-- TextBox: lớn hơn cho touch -->
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="MinHeight" Value="52"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <!-- DataGrid row height -->
            <Style TargetType="DataGridRow">
                <Setter Property="MinHeight" Value="52"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="DataGridCell">
                <Setter Property="Padding" Value="12,8"/>
            </Style>

            <!-- ScrollViewer: touch panning -->
            <Style TargetType="ScrollViewer">
                <Setter Property="PanningMode" Value="VerticalFirst"/>
            </Style>

            <!-- DataTemplates: ViewModel → Page View (dùng trong ContentControl) -->
            <DataTemplate DataType="{x:Type vm:JobListViewModel}">
                <pages:JobListPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:OperationViewModel}">
                <pages:OperationPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ProductListViewModel}">
                <pages:ProductListPage/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
