# ============================================================
# Shopfloor Manager — Environment Variables
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env vào git
# ============================================================

# Database (PostgreSQL)
DB_USER=shopfloor
DB_PASSWORD=changeme_strong_password
DB_NAME=shopfloor

# JWT
JWT_SECRET=changeme_replace_with_64_char_random_string_minimum_required
JWT_EXPIRY_HOURS=8

# MinIO (File Storage)
MINIO_USER=minioadmin
MINIO_PASSWORD=changeme_minio_password
MINIO_BUCKET=shopfloor-storage

# MQTT (Mosquitto — CNC data)
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TOPIC_CNC=factory/cnc/#

# Email — SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@shopfloor.local

# Microsoft Teams webhook (optional)
TEAMS_WEBHOOK_URL=

# App
NEXT_PUBLIC_APP_NAME=Shopfloor Manager
NEXT_PUBLIC_API_URL=http://localhost:5000
